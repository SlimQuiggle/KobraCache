<Window x:Class="KobraCache.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KobraCache" Icon="Assets/KobraCache.ico" Height="760" Width="1180" MinHeight="680" MinWidth="1040"
        Background="#F6FAFB" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushStrong" Color="#B6CDD6" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0F766E" />
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="AccentWarmBrush" Color="#F97316" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B91C1C" />
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="BorderBrush" Value="#89A9B3" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource BaseButton}" />
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="#0D9488" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="MinHeight" Value="36" />
        </Style>
        <Style x:Key="BlueButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#DBEAFE" />
            <Setter Property="BorderBrush" Value="#60A5FA" />
            <Setter Property="Foreground" Value="#1D4ED8" />
        </Style>
        <Style x:Key="WarmButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#FFEDD5" />
            <Setter Property="BorderBrush" Value="#FDBA74" />
            <Setter Property="Foreground" Value="#C2410C" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="#89A9B3" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="IsReadOnly" Value="False" />
            <Setter Property="RowHeight" Value="34" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="BorderBrush" Value="#B6CDD6" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="8" BorderBrush="#BAE6FD" BorderThickness="1" Padding="12" Margin="0,0,0,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#E0F2FE" Offset="0" />
                    <GradientStop Color="#ECFDF5" Offset="0.56" />
                    <GradientStop Color="#FFF7ED" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Assets/KobraCacheLogo.png" Width="44" Height="44" Margin="0,0,10,0" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="KobraCache" FontSize="28" FontWeight="SemiBold" Foreground="#0F172A" />
                        <TextBlock x:Name="VersionText" Text="v0.6.0" Foreground="#0F766E" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Check for Updates" Style="{StaticResource WarmButton}" Click="CheckForUpdates_Click" />
                    <Button Content="Open Logs" Style="{StaticResource BlueButton}" Click="OpenLogs_Click" />
                    <TextBlock x:Name="HeaderStatusText" Text="Ready" VerticalAlignment="Center"
                               Foreground="#334155" TextAlignment="Right" FontWeight="SemiBold" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Import printers from Anycubic Slicer Next" VerticalAlignment="Center"
                           FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,12,0" />
                <Button Grid.Column="1" Content="Import Slicer LAN" Style="{StaticResource WarmButton}" Click="ImportSlicerLan_Click" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <CheckBox x:Name="CloudOptInCheckBox" Content="Allow Slicer cloud token import"
                              VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Button Content="Import Cloud Printers" Style="{StaticResource WarmButton}" Click="ImportSlicerCloud_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Printers" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" />
                        <WrapPanel Grid.Row="1" Margin="0,8,0,0">
                            <Button Content="View Files" Style="{StaticResource PrimaryButton}" Click="PreviewSelectedPrinter_Click" />
                            <Button Content="Refresh Status" Style="{StaticResource BlueButton}" Click="RefreshStatus_Click" />
                            <Button Content="Remove Selected" Click="RemoveSelectedPrinter_Click" />
                        </WrapPanel>
                    </Grid>

                    <DataGrid x:Name="PrintersGrid" Grid.Row="1" ItemsSource="{Binding Printers}"
                              SelectionChanged="PrintersGrid_SelectionChanged" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="112" />
                            <DataGridTextColumn Header="Mode" Binding="{Binding CapabilityText}" Width="118" />
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="98" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <TextBlock x:Name="SelectedPrinterText" Text="No printer selected" Foreground="#475569" />
                        <TextBlock x:Name="SelectedPrinterDetailText" Margin="0,4,0,0" Foreground="#64748B" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox x:Name="LocalTargetCheckBox" Content="Local cache" IsChecked="True" Margin="0,0,10,0" />
                            <CheckBox x:Name="UsbTargetCheckBox" Content="USB" IsChecked="False" Margin="0,0,10,0" />
                            <CheckBox x:Name="CloudTargetCheckBox" Content="Cloud" IsChecked="False" />
                        </StackPanel>

                        <Button x:Name="SelectAllButton" Grid.Column="2" Content="Select All" Style="{StaticResource BlueButton}" Click="SelectAllFiles_Click" />
                        <Button Grid.Column="4" Content="View Files" Style="{StaticResource PrimaryButton}" Click="Preview_Click" />
                    </Grid>

                    <DataGrid x:Name="FilesGrid" Grid.Row="1" ItemsSource="{Binding FilePreviewRows}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Delete" Width="64" IsReadOnly="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding CanDeleteWhenSelected}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Storage" Binding="{Binding StorageTargetText}" Width="92" IsReadOnly="True" />
                            <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="*" IsReadOnly="True" />
                            <DataGridTextColumn Header="Date" Binding="{Binding DateText}" Width="144" IsReadOnly="True" />
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="92" IsReadOnly="True" />
                            <DataGridTextColumn Header="Status" Binding="{Binding EligibilityText}" Width="210" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <DockPanel Grid.Row="2" Margin="0,10,0,0">
                        <TextBlock x:Name="PreviewSummaryText" DockPanel.Dock="Left" Text="No files loaded" Foreground="#475569" VerticalAlignment="Center" />
                        <Button x:Name="DeleteSelectedButton" DockPanel.Dock="Right" Content="Delete Selected"
                                Background="#FEE2E2" BorderBrush="#FCA5A5" Foreground="{StaticResource DangerBrush}"
                                IsEnabled="False" Click="DeleteSelected_Click" />
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Margin="0,12,0,0" Background="#E0F2FE" BorderBrush="#BAE6FD" BorderThickness="1" CornerRadius="8" Padding="10,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="Created by Flex3Designs" Foreground="#C2410C" FontWeight="SemiBold" />
                <TextBlock x:Name="FooterStatusText" Text="Ready" Foreground="#334155" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
