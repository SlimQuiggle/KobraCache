<Window x:Class="KobraCache.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KobraCache" Icon="Assets/KobraCache.ico" Height="760" Width="1180" MinHeight="680" MinWidth="1040"
        Background="#F4F6F8" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushStrong" Color="#CBD5E1" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B91C1C" />
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="BorderBrush" Value="#94A3B8" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="#94A3B8" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="IsReadOnly" Value="False" />
            <Setter Property="RowHeight" Value="34" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="Assets/KobraCacheLogo.png" Width="44" Height="44" Margin="0,0,10,0" />
                <TextBlock Text="KobraCache" FontSize="28" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Open Logs" Click="OpenLogs_Click" />
                <TextBlock x:Name="HeaderStatusText" Text="Ready" VerticalAlignment="Center"
                           Foreground="#475569" TextAlignment="Right" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Printer IP" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="ManualIpTextBox" Grid.Column="1" VerticalAlignment="Center" />
                <Button Grid.Column="2" Content="Add IP" Click="AddManualIp_Click" />

                <Button Grid.Column="4" Content="Import Slicer LAN" Click="ImportSlicerLan_Click" />
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <CheckBox x:Name="CloudOptInCheckBox" Content="Allow Slicer cloud token import"
                              VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Button Content="Import Cloud Printers" Click="ImportSlicerCloud_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Printers" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" />
                        <Button DockPanel.Dock="Right" Content="Refresh Status" Click="RefreshStatus_Click" />
                    </DockPanel>

                    <DataGrid x:Name="PrintersGrid" Grid.Row="1" ItemsSource="{Binding Printers}"
                              SelectionChanged="PrintersGrid_SelectionChanged" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="112" />
                            <DataGridTextColumn Header="Mode" Binding="{Binding CapabilityText}" Width="118" />
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="78" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <TextBlock x:Name="SelectedPrinterText" Text="No printer selected" Foreground="#475569" />
                        <TextBlock x:Name="SelectedPrinterDetailText" Margin="0,4,0,0" Foreground="#64748B" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox x:Name="LocalTargetCheckBox" Content="Local cache" IsChecked="True" Margin="0,0,10,0" />
                            <CheckBox x:Name="UsbTargetCheckBox" Content="USB" IsChecked="True" Margin="0,0,10,0" />
                            <CheckBox x:Name="CloudTargetCheckBox" Content="Cloud" IsChecked="True" />
                        </StackPanel>

                        <TextBlock Grid.Column="3" Text="Retention" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox x:Name="RetentionComboBox" Grid.Column="4" SelectionChanged="RetentionComboBox_SelectionChanged">
                            <ComboBoxItem Content="30 days and older" Tag="Days30" IsSelected="True" />
                            <ComboBoxItem Content="60 days and older" Tag="Days60" />
                            <ComboBoxItem Content="90 days and older" Tag="Days90" />
                            <ComboBoxItem Content="Custom cutoff" Tag="CustomDate" />
                        </ComboBox>

                        <DatePicker x:Name="CustomCutoffDatePicker" Grid.Column="6" IsEnabled="False" />
                        <Button Grid.Column="8" Content="Preview" Click="Preview_Click" />
                    </Grid>

                    <DataGrid x:Name="FilesGrid" Grid.Row="1" ItemsSource="{Binding FilePreviewRows}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Delete" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="64" />
                            <DataGridTextColumn Header="Storage" Binding="{Binding StorageTargetText}" Width="92" IsReadOnly="True" />
                            <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="*" IsReadOnly="True" />
                            <DataGridTextColumn Header="Date" Binding="{Binding DateText}" Width="144" IsReadOnly="True" />
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="92" IsReadOnly="True" />
                            <DataGridTextColumn Header="Result" Binding="{Binding EligibilityText}" Width="210" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <DockPanel Grid.Row="2" Margin="0,10,0,0">
                        <TextBlock x:Name="PreviewSummaryText" DockPanel.Dock="Left" Text="No preview loaded" Foreground="#475569" VerticalAlignment="Center" />
                        <Button x:Name="DeleteSelectedButton" DockPanel.Dock="Right" Content="Delete Selected"
                                Background="#FEE2E2" BorderBrush="#FCA5A5" Foreground="{StaticResource DangerBrush}"
                                IsEnabled="False" Click="DeleteSelected_Click" />
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>

        <StatusBar Grid.Row="3" Margin="0,12,0,0" Background="#E2E8F0">
            <TextBlock x:Name="FooterStatusText" Text="Ready" Foreground="#334155" />
        </StatusBar>
    </Grid>
</Window>
