<Window x:Class="KobraCache.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KobraCache" Icon="Assets/KobraCache.ico" Height="760" Width="1180" MinHeight="680" MinWidth="1040"
        Background="#F6FAFB" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushStrong" Color="#B6CDD6" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0F766E" />
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="AccentWarmBrush" Color="#F97316" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B91C1C" />
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="BorderBrush" Value="#89A9B3" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource BaseButton}" />
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="#0D9488" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="MinHeight" Value="36" />
        </Style>
        <Style x:Key="BlueButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#DBEAFE" />
            <Setter Property="BorderBrush" Value="#60A5FA" />
            <Setter Property="Foreground" Value="#1D4ED8" />
        </Style>
        <Style x:Key="WarmButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#FFEDD5" />
            <Setter Property="BorderBrush" Value="#FDBA74" />
            <Setter Property="Foreground" Value="#C2410C" />
        </Style>
        <Style x:Key="WorkflowButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style x:Key="LanImportButton" TargetType="Button" BasedOn="{StaticResource WorkflowButton}">
            <Setter Property="Background" Value="#E0F2FE" />
            <Setter Property="BorderBrush" Value="#38BDF8" />
            <Setter Property="Foreground" Value="#075985" />
        </Style>
        <Style x:Key="CloudImportButton" TargetType="Button" BasedOn="{StaticResource WorkflowButton}">
            <Setter Property="Background" Value="#DCFCE7" />
            <Setter Property="BorderBrush" Value="#22C55E" />
            <Setter Property="Foreground" Value="#166534" />
        </Style>
        <Style x:Key="ViewFilesButton" TargetType="Button" BasedOn="{StaticResource WorkflowButton}">
            <Setter Property="Background" Value="#CCFBF1" />
            <Setter Property="BorderBrush" Value="#14B8A6" />
            <Setter Property="Foreground" Value="#0F766E" />
        </Style>
        <Style x:Key="StepBadge" TargetType="Border">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ButtonIcon" TargetType="Viewbox">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="#89A9B3" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="IsReadOnly" Value="False" />
            <Setter Property="RowHeight" Value="34" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="BorderBrush" Value="#B6CDD6" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="8" BorderBrush="#BAE6FD" BorderThickness="1" Padding="12" Margin="0,0,0,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#E0F2FE" Offset="0" />
                    <GradientStop Color="#ECFDF5" Offset="0.56" />
                    <GradientStop Color="#FFF7ED" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Assets/KobraCacheLogo.png" Width="44" Height="44" Margin="0,0,10,0" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="KobraCache" FontSize="28" FontWeight="SemiBold" Foreground="#0F172A" />
                        <TextBlock x:Name="VersionText" Text="v0.9.0" Foreground="#0F766E" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Check for Updates" Style="{StaticResource WarmButton}" Click="CheckForUpdates_Click" />
                    <Button Content="Open Logs" Style="{StaticResource BlueButton}" Click="OpenLogs_Click" />
                    <TextBlock x:Name="HeaderStatusText" Text="Ready" VerticalAlignment="Center"
                               Foreground="#334155" TextAlignment="Right" FontWeight="SemiBold" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Border Style="{StaticResource StepBadge}" Background="#0F766E">
                        <TextBlock Text="1" Foreground="#FFFFFF" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Import Printers" VerticalAlignment="Center" FontSize="16"
                               FontWeight="SemiBold" Foreground="#0F172A" />
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource LanImportButton}" Click="ImportSlicerLan_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Style="{StaticResource ButtonIcon}">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="#075985" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Data="M4,5 L20,5 L20,14 L4,14 Z M12,14 L12,19 M8,19 L16,19 M7,9 L17,9 M10,11 L12,9 L14,11 M12,9 L12,13" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Import Slicer LAN" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Style="{StaticResource CloudImportButton}" Click="ImportSlicerCloud_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Style="{StaticResource ButtonIcon}">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="#166534" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Data="M7,17 L18,17 C20,17 21.5,15.5 21.5,13.5 C21.5,11.4 19.8,9.8 17.7,9.8 C17.1,7.1 14.8,5 12,5 C9.5,5 7.4,6.6 6.6,9.1 C4.3,9.4 2.5,11.2 2.5,13.5 C2.5,15.5 4.2,17 7,17 M12,8 L12,15 M9.5,12.5 L12,15 L14.5,12.5" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Import Cloud Printers" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource StepBadge}" Background="#2563EB">
                                <TextBlock Text="2" Foreground="#FFFFFF" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Printers" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center" />
                        </StackPanel>
                        <WrapPanel Grid.Row="1" Margin="0,8,0,0">
                            <Button Content="Refresh Status" Style="{StaticResource BlueButton}" Click="RefreshStatus_Click" />
                            <Button Content="Remove Selected" Click="RemoveSelectedPrinter_Click" />
                        </WrapPanel>
                    </Grid>

                    <DataGrid x:Name="PrintersGrid" Grid.Row="1" ItemsSource="{Binding Printers}"
                              SelectionChanged="PrintersGrid_SelectionChanged" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="112" />
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="98" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <TextBlock x:Name="SelectedPrinterText" Text="No printer selected" Foreground="#475569" />
                        <TextBlock x:Name="SelectedPrinterDetailText" Margin="0,4,0,0" Foreground="#64748B" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox x:Name="LocalTargetCheckBox" Content="Local cache" IsChecked="True" Margin="0,0,10,0" />
                            <CheckBox x:Name="UsbTargetCheckBox" Content="USB" IsChecked="False" Margin="0,0,10,0" />
                            <CheckBox x:Name="CloudTargetCheckBox" Content="Cloud" IsChecked="False" />
                        </StackPanel>

                        <Button x:Name="SelectAllButton" Grid.Column="2" Content="Select All" Style="{StaticResource BlueButton}" Click="SelectAllFiles_Click" />
                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource StepBadge}" Background="#F97316">
                                <TextBlock Text="3" Foreground="#FFFFFF" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Button Style="{StaticResource ViewFilesButton}" Click="Preview_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Viewbox Style="{StaticResource ButtonIcon}">
                                        <Canvas Width="24" Height="24">
                                            <Path Stroke="#0F766E" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                  Data="M6,4 L14,4 L19,9 L19,20 L6,20 Z M14,4 L14,9 L19,9 M10,14 C10,12.4 11.4,11 13,11 C14.6,11 16,12.4 16,14 C16,15.6 14.6,17 13,17 C11.4,17 10,15.6 10,14 M15.2,16.2 L17.5,18.5" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="View Files" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <DataGrid x:Name="FilesGrid" Grid.Row="1" ItemsSource="{Binding FilePreviewRows}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Delete" Width="64" IsReadOnly="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding CanDeleteWhenSelected}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Storage" Binding="{Binding StorageTargetText}" Width="92" IsReadOnly="True" />
                            <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="*" IsReadOnly="True" />
                            <DataGridTextColumn Header="Date" Binding="{Binding DateText}" Width="144" IsReadOnly="True" />
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="92" IsReadOnly="True" />
                            <DataGridTextColumn Header="Status" Binding="{Binding EligibilityText}" Width="210" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <DockPanel Grid.Row="2" Margin="0,10,0,0">
                        <TextBlock x:Name="PreviewSummaryText" DockPanel.Dock="Left" Text="No files loaded" Foreground="#475569" VerticalAlignment="Center" />
                        <Button x:Name="DeleteSelectedButton" DockPanel.Dock="Right" Content="Delete Selected"
                                Background="#FEE2E2" BorderBrush="#FCA5A5" Foreground="{StaticResource DangerBrush}"
                                IsEnabled="False" Click="DeleteSelected_Click" />
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Margin="0,12,0,0" Background="#E0F2FE" BorderBrush="#BAE6FD" BorderThickness="1" CornerRadius="8" Padding="10,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="Created by Flex3Designs" Foreground="#C2410C" FontWeight="SemiBold" />
                <TextBlock x:Name="FooterStatusText" Text="Ready" Foreground="#334155" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
